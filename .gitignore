
# ── Terraform state — NEVER commit these ──────────────────────
*.tfstate
*.tfstate.*
*.tfstate.backup
.terraform/
.terraform.lock.hcl
terraform.tfplan
tfplan
*.tfplan

# ── Variable files with real values — NEVER commit ────────────
*.tfvars
!*.tfvars.example
terraform.tfvars.json

# ── Credentials and secrets — NEVER commit these ──────────────
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer
*.der
.aws/
credentials
secrets/
*secret*
*password*
*token*

# ── Environment variables ──────────────────────────────────────
.env
.env.*
*.env

# ── Crash and override files ───────────────────────────────────
crash.log
crash.*.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# ── Generated docs ─────────────────────────────────────────────
docs/
.terraform-docs/

# ── OS generated files ─────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# ── Editor and IDE ─────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*.swn
*~
.history/
*.sublime-project
*.sublime-workspace

# ── Logs ──────────────────────────────────────────────────────
*.log
logs/

# ── Temporary files ────────────────────────────────────────────
tmp/
temp/
.tmp/
*.tmp
*.temp
*.bak
*.backup

# ── Kubernetes configs generated by Terraform ─────────────────
kubeconfig
kubeconfig.*
*.kubeconfig

# ── Helm ──────────────────────────────────────────────────────
charts/
Chart.lock

# ── Terragrunt ────────────────────────────────────────────────
.terragrunt-cache/
terragrunt.hcl.backup